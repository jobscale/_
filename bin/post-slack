#!/usr/bin/env bash
set -u

DATA="${1:-}"
if [[ -z "$DATA" ]]; then
  echo "Usage: [env::CHANNEL] [env::TIMEOUT] $0 <message>"
  exit 1
fi
ENDPOINT=https://jsx.jp/api/slack
GIP="$(hostname) - $(curl -s https://inet-ip.info/ip)"
OPTION=
[[ "${TIMEOUT:-}" != "" ]] && OPTION="-m ${TIMEOUT}"

postSlack() {
  PAYLOAD="{\"icon_emoji\":\":anchor:\",\"username\":\"$(hostname)\",\"text\":\"$DATA\\n$GIP\""
  if [[ -n "${CHANNEL:-}" ]]; then
    PAYLOAD+=",\"channel\":\"${CHANNEL}\""
  fi
  PAYLOAD+="}"

  curl $OPTION -s -X POST -H 'Content-Type: application/json' ${ENDPOINT} \
  --data "${PAYLOAD}" > /dev/null || echo
}

postSlack
