#!/usr/bin/env bash
set -eu

readonly T_FILE="/tmp/quest-color.log"

check-color() {
  local -r color_info=$(import -window root -crop 1x1+$1+$2 txt:- | grep -Po 'srgb\(\K\d+,\d+,\d+(?=\))')
  # xdotool mousemove $1 $2
  # sleep 0.2

  IFS=',' read -r R G B <<< "$color_info"

  if [[ "$R" -ge 15 ]] && [[ "$G" -ge 15 ]] && [[ "$B" -ge 15 ]]; then
    echo "OK"
    echo "OK $R $G $B" >> "${T_FILE}"
  else
    echo "NG"
    echo "NG $R $G $B" >> "${T_FILE}"
  fi
}

check-all() {
  local -r RES2=$(check-color 215 300)
  local -r RES3=$(check-color 215 400)
  local -r RES4=$(check-color 215 500)
  local -r RES1=$(check-color 215 600)
  # echo "$RES1 $RES2 $RES3 $RES4" 1>&2
  if [[ "$RES1 $RES2 $RES3 $RES4" == "OK OK OK OK" ]]; then
    echo "ALL OK"
  else
    echo "SOMEONE NG"
  fi
}

check-sub() {
  local -r RES2=$(check-color 115 300)
  local -r RES3=$(check-color 115 400)
  local -r RES4=$(check-color 115 500)
  local -r RES1=$(check-color 115 600)
  # echo "$RES1 $RES2 $RES3 $RES4" 1>&2
  if [[ "$RES1 $RES2 $RES3 $RES4" == "OK OK OK OK" ]]; then
    echo "ALL OK"
  else
    echo "SOMEONE NG"
  fi
}

check-three() {
  local -r RES2=$(check-color 15 300)
  local -r RES3=$(check-color 15 400)
  local -r RES4=$(check-color 15 500)
  local -r RES1=$(check-color 15 600)
  # echo "$RES1 $RES2 $RES3 $RES4" 1>&2
  if [[ "$RES1 $RES2 $RES3 $RES4" == "OK OK OK OK" ]]; then
    echo "ALL OK"
  else
    echo "SOMEONE NG"
  fi
}

main() {
  local RES=$(check-all)
  if [[ "$RES" != "ALL OK" ]]; then
    sleep 1
    RES=$(check-sub)
  fi
  if [[ "$RES" != "ALL OK" ]]; then
    sleep 1
    RES=$(check-three)
  fi
  echo $RES
}

main
