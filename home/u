update() {
  export DEBIAN_FRONTEND=noninteractive
  head -5 /etc/os-release
  . /etc/os-release

  echo "$(date -Iseconds) ### update"
  sudo apt-get update && sudo apt-get --just-print upgrade
  grep -r -i packagekit /etc/apt

  echo "$(date -Iseconds) ### upgrade"
  sudo apt-get upgrade -y --no-install-recommends

  echo "$(date -Iseconds) ### dist-upgrade"
  sudo apt-get dist-upgrade -y --no-install-recommends

  echo "$(date -Iseconds) ### autopurge"
  sudo apt-get autopurge -y
}

upgrade() {
  update
  sudo apt-get clean && sudo rm -fr /var/lib/apt/lists/*
}

{
  time upgrade
} 2>&1 | tee -a $HOME/.work/apt-upgrade.log
