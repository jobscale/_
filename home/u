update() {
  export DEBIAN_FRONTEND=noninteractive
  cat /etc/os-release | head -5
  . /etc/os-release

  echo "$(date -Iseconds) ### update"
  sudo apt update && APT_PAGER=cat unbuffer apt list --upgradable
  grep -r -i packagekit /etc/apt

  echo "$(date -Iseconds) ### upgrade"
  sudo apt upgrade -y --no-install-recommends

  echo "$(date -Iseconds) ### full-upgrade"
  sudo apt full-upgrade -y --no-install-recommends

  echo "$(date -Iseconds) ### autoremove"
  sudo apt autoremove --purge -y
}

full-update() {
  update
  sudo apt clean && sudo rm -fr /var/lib/apt/lists/*
}

{
  time full-update
} 2>&1 | tee -a $HOME/.work/apt-update.log
