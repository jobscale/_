#!/usr/bin/env bash
set -eu

export DEBIAN_FRONTEND=noninteractive

symbolic-links() {
  mv ダウンロード Downloads && ln -s Downloads ダウンロード
  mv テンプレート Templates && ln -s Templates テンプレート
  mv デスクトップ Desktop && ln -s Desktop デスクトップ
  mv ドキュメント Documents && ln -s Documents ドキュメント
  mv ビデオ Videos && ln -s Videos ビデオ
  mv 音楽 Music && ln -s Music 音楽
  mv 画像 Pictures && ln -s Pictures 画像
  mv 公開 Public && ln -s Public 公開
}

disable-services() {
  {
    sudo systemctl disable --now avahi-daemon
    sudo systemctl mask avahi-daemon
  }
  {
    sudo systemctl disable --now exim4
    sudo systemctl mask exim4
  }
  {
    sudo systemctl disable --now cups
    sudo systemctl mask cups
  }
  {
    sudo systemctl disable --now avahi-daemon.socket
    sudo systemctl mask avahi-daemon.socket
  }
  {
    sudo systemctl disable --now avahi-daemon
    sudo systemctl mask avahi-daemon
  }
  {
    sudo systemctl disable --now ModemManager
    sudo systemctl mask ModemManager
  }
  sudo apt-get purge -y exim4 exim4-base exim4-config exim4-daemon-light
  sudo apt-get purge -y cups
  sudo apt-get autoremove --purge -y
}

debian-2022() {
  sudo apt-get update
  sudo apt-get install -y --no-install-recommends \
    terminator ibus-mozc conky gdm3 ffmpeg libsecret-tools
  sudo apt-get install \
    task-japanese-desktop
}

debian-2025() {
  sudo apt-get update
  sudo apt-get install -y --no-install-recommends \
    terminator ibus-mozc conky-all gdm3 ffmpeg libsecret-tools
  sudo apt-get install \
    task-japanese-desktop
  sudo dpkg-reconfigure gdm3
}

ubuntu() {
  sudo apt-get update
  sudo apt-get install -y --no-install-recommends \
    terminator ibus-mozc conky gdm3 ffmpeg libsecret-tools
  sudo apt-get install \
    language-pack-gnome-ja
}

kali-rolling() {
  sudo apt-get update
  sudo apt-get install -y --no-install-recommends \
    terminator ibus-mozc conky gdm3 ffmpeg libsecret-tools
  sudo apt-get install \
    task-japanese-desktop
  sudo dpkg-reconfigure locales
  sudo systemctl enable ssh --now
}

extra() {
  sudo apt-get install -y --no-install-recommends \
    kazam copyq
}

main() {
  echo "$(lsb_release -a 2>/dev/null || echo "$(date --rfc-3339=seconds) [WARN] No LSB modules are available.")"
  . /etc/os-release

  start() {
    echo "$(date --rfc-3339=seconds) [INFO] START  graphical for $VERSION_CODENAME"
  }
  finish() {
    echo "$(date --rfc-3339=seconds) [INFO] FINISH graphical for $VERSION_CODENAME"
  }
  trap 'finish' EXIT
  start

  case "$VERSION_CODENAME" in
    trixie)
      debian-2025
      ;;
    bookworm|bullseye|buster)
      debian-2022
      ;;
    noble|jammy|focal)
      ubuntu
      ;;
    kali-rolling)
      kali-rolling
      ;;
    *)
      echo "$(date --rfc-3339=seconds) [FAIL] Unsupported distribution: $VERSION_CODENAME"
      exit 1
      ;;
  esac
}

main "$@"
