#!/usr/bin/env bash
set -eu

# dependent on bash >= 5.2

play() {
  ffplay -nodisp -autoexit -ss 0 -t 2 sand.mp3 >/dev/null 2>&1
}

readonly FILE_TIME="/tmp/quest-force-time"
readonly FILE_COUNT_LEFT="/tmp/quest-count-left"
readonly FILE_LOG="/tmp/quest-cursor.log"

# next tick emitter
update-time() {
  echo $(cat ${FILE_TIME} 2>/dev/null)
  rm -f ${FILE_TIME}
}

# update count left
update-count() {
  echo $(cat ${FILE_COUNT_LEFT} 2>/dev/null)
  rm -f ${FILE_COUNT_LEFT}
}

notification() {
  web-push "Finish build the troops"
  post-slack "Finish build the troops"
  play
}

# activation per 100 seconds
ACTIVATE=$(date +%s)
loop() {
  local fire_time=$(( $(date +%s) + $1 ))
  local SHOULD_NOTIFY=$(( ${2:-0} == 0 ))
  while [ $(date +%s) -lt $fire_time ]; do
    local REMAIN=$(( fire_time - $(date +%s) ))
    if [[ "$SHOULD_NOTIFY" -eq 1 && "$REMAIN" -le 10 ]]; then
      SHOULD_NOTIFY=0
      notification
    fi
    printf '\r%5d ' $REMAIN
    if [[ $(( $(date +%s) - ACTIVATE )) -ge 100 ]]; then
      ACTIVATE=$(date +%s)
      xdotool mousemove $(( 100 + $(( $(date +%s%3N) % 100 )) )) 400
      sleep 0.2
      xdotool mousemove $(( 100 + $(( $(date +%s%3N) % 100 )) )) 200
    fi
    sleep 1
    local DELAY=6
    while [[ "$(./check-color)"  != "ALL OK" ]]; do
      play
      web-push "Blocking - building the troops"
      post-slack "Blocking - building the troops"
      sleep $DELAY
      DELAY=$(( DELAY + 6 ))
      if [[ $DELAY -gt 36 ]]; then exit 1; fi
    done
    local FAST_UPDATE=$(update-time)
    if [[ ! -z "$FAST_UPDATE" ]]; then
      fire_time=$(( $(date +%s) + FAST_UPDATE ))
    fi
  done
  printf '\r%5d\n' 0
}

readonly ADDING=$1
readonly COUNT=$2
DURATION=$3
if [[ -z "${4:-}" ]]; then
  IFS=, read -r XX YY <<< "$(./get-point)"
else
  IFS=, read -r XX YY <<< "$4"
fi
declare -r XX YY
echo "cursor $XX $YY" >> "${FILE_LOG}"
readonly INTERVAL=8

fire() {
  xdotool mousemove $XX $YY
  sleep 2
  xdotool mousedown 1
  sleep 0.2
  xdotool mouseup 1
}

main() {
  echo
  local step=0
  local count=${COUNT}
  while [[ $count -gt 0 ]]; do
    count=$(( count - 1 ))
    step=$(( step + 1 ))
    DURATION=$(( DURATION + ADDING ))
    local WAIT_TIME=$(( INTERVAL + DURATION ))
    local REMAINING_STEPS=$(( count + 1 ))
    local REMAINING_TOTAL=$((
      REMAINING_STEPS * WAIT_TIME +
      (ADDING * REMAINING_STEPS * (REMAINING_STEPS - 1)) / 2
    ))
    fire
    echo -ne "\e[A\r\e[2K"
    echo " $( printf '(%4d sec) Step %3d' ${REMAINING_TOTAL} ${step} ) ... left - $( printf '%3d %3d' ${count} ${DURATION} )"
    echo -n "$(printf '%8s ' ' ') x,y $(./get-point)"
    loop $WAIT_TIME $count
    local FAST_UPDATE=$(update-count)
    if [[ ! -z "$FAST_UPDATE" ]]; then
      count=$(( FAST_UPDATE + 0 ))
    fi
  done
  echo
}

main
